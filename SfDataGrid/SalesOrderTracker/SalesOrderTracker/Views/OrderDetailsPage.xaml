<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalesOrderTracker.Views.OrderDetailsPage"
             Title="Order Details">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="Order Details" FontSize="28" FontAttributes="Bold" />

            <Frame CornerRadius="8" Padding="12" BackgroundColor="{DynamicResource SurfaceElevated}" HasShadow="False">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <StackLayout Grid.Column="0" Spacing="4">
                        <Label Text="{Binding CurrentOrder.OrderNumber}" FontAttributes="Bold" FontSize="18" />
                        <Label Text="{Binding CustomerName}" FontSize="14" TextColor="Gray" />
                        <Label Text="{Binding CurrentOrder.OrderDate, StringFormat='{}{0:f}'}" FontSize="12" TextColor="Gray" />
                    </StackLayout>

                    <StackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                        <Label Text="Status" FontSize="12" HorizontalOptions="End" />
                        <Label Text="{Binding CurrentOrder.Status}" Padding="8" HorizontalOptions="End" FontAttributes="Bold">
                            <Label.BackgroundColor>
                                <OnPlatform x:TypeArguments="Color">
                                    <On Platform="Android,iOS" Value="Transparent" />
                                    <On Platform="WinUI,MacCatalyst" Value="Transparent" />
                                </OnPlatform>
                            </Label.BackgroundColor>
                        </Label>
                    </StackLayout>
                </Grid>
            </Frame>

            <!-- Line items -->
            <Frame CornerRadius="8" Padding="8" Style="{StaticResource CardFrame}">
                <StackLayout>
                    <Label Text="Items" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding CurrentOrder.LineItems}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="6">
                                    <Label Text="{Binding ProductName}" />
                                    <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Label Text="{Binding Quantity}" />
                                        <Label Text="x" />
                                        <Label Text="{Binding UnitPrice, StringFormat='{}{0:C}'}" />
                                    </StackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>

            <!-- Status history -->
            <Frame CornerRadius="8" Padding="8" Style="{StaticResource CardFrame}">
                <StackLayout>
                    <Label Text="Status History" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding CurrentOrder.StatusHistory}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="4">
                                    <Label Text="{Binding ChangedAt, StringFormat='{0:g}'}" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding OldStatus}" FontSize="12" HorizontalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding NewStatus}" FontSize="12" HorizontalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>

            <!-- Actions -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Fill">
                <Button Text="Processing" Command="{Binding MarkProcessingCommand}" HorizontalOptions="FillAndExpand" />
                <Button Text="Shipped" Command="{Binding MarkShippedCommand}" HorizontalOptions="FillAndExpand" />
                <Button Text="Delivered" Command="{Binding MarkDeliveredCommand}" HorizontalOptions="FillAndExpand" />
                <Button Text="Cancel" Command="{Binding CancelOrderCommand}" BackgroundColor="#E57373" TextColor="White" HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>