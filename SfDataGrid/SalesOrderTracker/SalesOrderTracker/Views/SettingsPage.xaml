<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalesOrderTracker.Views.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="16" Spacing="16">
        <!-- Header -->
        <Label Text="Settings &amp; About" FontSize="28" FontAttributes="Bold" TextColor="#512BD4" />

        <!-- App Info Section -->
        <Frame BorderColor="#E1E1E1" Padding="12" CornerRadius="8" BackgroundColor="{DynamicResource CardBackgroundBrush}" HasShadow="False">
            <VerticalStackLayout Spacing="8">
                <Label Text="App Information" FontSize="16" FontAttributes="Bold" />
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Application:" FontSize="12" TextColor="#6E6E6E" />
                    <Label Text="SalesOrderTracker" FontSize="14" FontAttributes="Bold" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Version:" FontSize="12" TextColor="#6E6E6E" />
                    <Label Text="{Binding AppVersion}" FontSize="14" FontAttributes="Bold" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Description:" FontSize="12" TextColor="#6E6E6E" />
                    <Label Text="Local-first Sales Order management with Syncfusion UI" FontSize="13" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Preferences Section -->
        <Frame BorderColor="#E1E1E1" Padding="12" CornerRadius="8" BackgroundColor="{DynamicResource CardBackgroundBrush}" HasShadow="False">
            <VerticalStackLayout Spacing="8">
                <Label Text="Preferences" FontSize="16" FontAttributes="Bold" />
                
                <Frame BorderColor="Transparent" Padding="0" BackgroundColor="{DynamicResource CardBackgroundBrush}" CornerRadius="6" HasShadow="False">
                    <HorizontalStackLayout Padding="8" Spacing="8">
                        <Label Text="Enable Sample Data on Startup" FontSize="13" VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                        <Switch IsToggled="{Binding EnableSampleData, Mode=TwoWay}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <Frame BorderColor="Transparent" Padding="0" BackgroundColor="{DynamicResource CardBackgroundBrush}" CornerRadius="6" HasShadow="False">
                    <HorizontalStackLayout Padding="8" Spacing="8">
                        <Label Text="Use DummyJSON (remote)" FontSize="13" VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                        <Switch IsToggled="{Binding UseDummyJson, Mode=TwoWay}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!--<Frame BorderColor="Transparent" Padding="0" BackgroundColor="#F5F5F5" CornerRadius="6" HasShadow="False">
                    <HorizontalStackLayout Padding="8" Spacing="8">
                        <Label Text="App Theme" FontSize="13" VerticalOptions="Center" HorizontalOptions="Start" />
                        <Picker SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" SelectedIndexChanged="Picker_SelectedIndexChanged" WidthRequest="140" HorizontalOptions="End">
                            <Picker.Items>
                                <x:String>System</x:String>
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                            </Picker.Items>
                        </Picker>
                    </HorizontalStackLayout>
                </Frame>-->

                <Label Text="Sample data is generated locally using Bogus or fetched from DummyJSON as fallback." 
                       FontSize="11" TextColor="#999999" LineBreakMode="WordWrap" />

                <Button Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="Transparent" TextColor="{DynamicResource PrimaryColor}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Footer -->
        <Label Text="© 2026 SalesOrderTracker. Built with .NET MAUI and Syncfusion." 
               FontSize="11" TextColor="#999999" HorizontalOptions="Center" HorizontalTextAlignment="Center" 
               LineBreakMode="WordWrap" Margin="0,20,0,0" />
    </VerticalStackLayout>

</ContentPage>
