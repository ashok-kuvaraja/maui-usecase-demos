<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SalesOrderTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SalesOrderTracker"
    xmlns:views="clr-namespace:SalesOrderTracker.Views"
    Title="SalesOrderTracker"
    BackgroundColor="#FFFFFF"
    ForegroundColor="#512BD4">

        <!-- Use TabBar on Android and iOS for bottom tab navigation; use a flyout on desktop platforms -->
        <TabBar IsVisible="{OnPlatform Android=true, iOS=true, WinUI=false, MacCatalyst=false}">
            <ShellContent
                Title="Orders"
                Icon="list_icon.png"
                ContentTemplate="{DataTemplate views:OrderListPage}"
                Route="OrderListPage" />

            <ShellContent
                Title="Settings"
                Icon="settings_icon.png"
                ContentTemplate="{DataTemplate views:SettingsPage}"
                Route="SettingsPage" />
        </TabBar>

    <FlyoutItem Title="Orders" Icon="list_icon.png" IsVisible="{OnPlatform WinUI=true, MacCatalyst=true, Android=false, iOS=false}">
        <Tab Title="Orders">
            <ShellContent ContentTemplate="{DataTemplate views:OrderListPage}" Route="OrderListPage" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Settings" Icon="settings_icon.png" IsVisible="{OnPlatform WinUI=true, MacCatalyst=true, Android=false, iOS=false}">
        <Tab Title="Settings">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage" />
        </Tab>
    </FlyoutItem>

</Shell>
