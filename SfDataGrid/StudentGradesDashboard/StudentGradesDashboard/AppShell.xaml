<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudentGradesDashboard.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StudentGradesDashboard"
    xmlns:views="clr-namespace:StudentGradesDashboard.Views"
    Title="Student Grades Dashboard">

    <!-- Define navigation routes -->
    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="dashboard.png"
            Route="dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}" />
    </TabBar>

</Shell>
